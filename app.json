{
  "expo": {
    "name": "Evven",
    "slug": "Evven",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Img/EvenUp-black.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/Img/EvenUp-black.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/Img/EvenUp-black.png",
        "backgroundImage": "./assets/Img/EvenUp-black.png",
        "monochromeImage": "./assets/Img/EvenUp-black.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/Img/EvenUp-black.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
